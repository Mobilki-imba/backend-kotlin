{
  "info": {
    "name": "Trading BFF",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        { "name": "Live", "request": { "method": "GET", "url": "{{baseUrl}}/health/live" } },
        { "name": "Ready", "request": { "method": "GET", "url": "{{baseUrl}}/health/ready" } }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', json.accessToken);",
                  "pm.collectionVariables.set('refreshToken', json.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"alice@example.com\",\"password\":\"Strong1Pass\",\"displayName\":\"Alice\"}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', json.accessToken);",
                  "pm.collectionVariables.set('refreshToken', json.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"email\":\"alice@example.com\",\"password\":\"Strong1Pass\"}" }
          }
        },
        {
          "name": "Refresh",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/refresh",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"refreshToken\":\"{{refreshToken}}\"}" }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/logout",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"refreshToken\":\"{{refreshToken}}\"}" }
          }
        }
      ]
    },
    {
      "name": "Instruments",
      "item": [
        { "name": "List", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/instruments",
          "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }] } },
        { "name": "Details", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/instruments/1",
          "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }] } },
        { "name": "Candles", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/instruments/1/candles?interval=1m&limit=50",
          "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }] } },
        { "name": "OrderBook", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/instruments/1/orderbook",
          "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }] } }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Place MARKET BUY",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/v1/orders",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{$guid}}" }
            ],
            "body": { "mode": "raw", "raw": "{\"instrumentId\":1,\"side\":\"BUY\",\"type\":\"MARKET\",\"quantity\":10}" }
          }
        },
        {
          "name": "Place LIMIT BUY",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/v1/orders",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{$guid}}" }
            ],
            "body": { "mode": "raw", "raw": "{\"instrumentId\":1,\"side\":\"BUY\",\"type\":\"LIMIT\",\"price\":\"300.00\",\"quantity\":10}" }
          }
        },
        { "name": "List Active", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/orders?status=active",
          "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }] } },
        { "name": "History", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/orders?status=history",
          "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }] } }
      ]
    },
    {
      "name": "Portfolio & Trades",
      "item": [
        { "name": "Portfolio", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/portfolio",
          "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }] } },
        { "name": "Trades", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/trades?limit=50",
          "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }] } }
      ]
    }
  ]
}
